# osint-toolkit — environment
#
# Everything works with NO keys. The pivot engine and the vast majority of the
# catalog need nothing at all. A handful of catalog tools call an API that wants
# a free key; set them here to unlock those tools, or leave blank to skip them.
#
# Copy this file to `.env` and fill in what you have:  cp .env.example .env

# Local API server port (default 8787)
PORT=8787

# Optional free API keys for a few catalog tools.
# Leave blank and those specific tools are simply skipped.

# Flickr — unlocks the 3 "find people by email/username/id" image tools.
# Get one free at https://www.flickr.com/services/apps/create/apply
FLICKR_API_KEY=

# YouTube Data API v3 — unlocks the video/channel metadata tools.
# Get one free at https://console.cloud.google.com (enable "YouTube Data API v3")
YOUTUBE_API_KEY=

# SharedCount — unlocks the domain social-share-count tool.
# Get one free at https://www.sharedcount.com
SHAREDCOUNT_API_KEY=
